{
  "expo": {
    "name": "Staxz",
    "slug": "staxz",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "staxz",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "owner": "make_d_great",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "android": {
      "package": "com.staxz.app",
      "adaptiveIcon": {
        "backgroundColor": "#7B4FA6",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      }
    },
    "ios": {
      "bundleIdentifier": "com.staxz.app",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "9e07bfc3-af81-424c-85d4-e7b5b3d844b1"
      }
    }
  }
}